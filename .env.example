# LLM provider (dev: ollama, prod: anthropic)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6-20250514

# Model artifact paths
FAISS_INDEX_PATH=/app/models/faiss/policy_index.faiss
FAISS_METADATA_PATH=/app/models/faiss/policy_metadata.pkl

# Ingestion service
INGESTION_SPACY_MODEL_PATH=en_core_web_sm
INGESTION_SPARK_MASTER=local[*]
INGESTION_MAX_UPLOAD_SIZE_MB=25
INGESTION_MAX_PAGES=200
INGESTION_RATE_LIMIT=10/minute

# Prediction service
PREDICTION_XGBOOST_MODEL_PATH=models/xgboost/claim_probability.json
PREDICTION_XGBOOST_SEVERITY_MODEL_PATH=models/xgboost/claim_severity.json
PREDICTION_RISK_THRESHOLD_LOW=0.25
PREDICTION_RISK_THRESHOLD_MODERATE=0.50
PREDICTION_RISK_THRESHOLD_HIGH=0.75
PREDICTION_RATE_LIMIT=20/minute

# Service URLs (used by the LLM service to call other services)
INGESTION_SERVICE_URL=http://ingestion:8000
PREDICTION_SERVICE_URL=http://prediction:8001
RAG_SERVICE_URL=http://rag:8002

# Application settings
LOG_LEVEL=INFO

# Kaggle (for data download scripts only)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key

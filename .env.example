# LLM service
LLM_PROVIDER=ollama
LLM_ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_ANTHROPIC_MODEL=claude-sonnet-4-6-20250514
LLM_OLLAMA_BASE_URL=http://localhost:11434
LLM_OLLAMA_MODEL=llama3
LLM_PREDICTION_SERVICE_URL=http://localhost:8001
LLM_RAG_SERVICE_URL=http://localhost:8002
LLM_MAX_TOOL_ROUNDS=5
LLM_RATE_LIMIT=10/minute
LLM_REQUEST_TIMEOUT=30.0

# Ingestion service
INGESTION_SPACY_MODEL_PATH=en_core_web_sm
INGESTION_SPARK_MASTER=local[*]
INGESTION_MAX_UPLOAD_SIZE_MB=25
INGESTION_MAX_PAGES=200
INGESTION_RATE_LIMIT=10/minute

# Prediction service
PREDICTION_XGBOOST_MODEL_PATH=models/xgboost/claim_probability.json
PREDICTION_XGBOOST_SEVERITY_MODEL_PATH=models/xgboost/claim_severity.json
PREDICTION_RISK_THRESHOLD_LOW=0.25
PREDICTION_RISK_THRESHOLD_MODERATE=0.50
PREDICTION_RISK_THRESHOLD_HIGH=0.75
PREDICTION_RATE_LIMIT=20/minute

# RAG service
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
RAG_INDEX_PATH=data/faiss/case_index.faiss
RAG_CASE_STORE_PATH=data/faiss/case_store.json
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.3
RAG_RATE_LIMIT=30/minute

# Application settings
LOG_LEVEL=INFO

# Kaggle (for data download scripts only)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key

# AWS Bedrock credentials
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Model IDs
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6-20250514-v1:0
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Model artifact paths (inside Docker containers)
FAISS_INDEX_PATH=/app/models/faiss/policy_index.faiss
FAISS_METADATA_PATH=/app/models/faiss/policy_metadata.pkl
XGBOOST_MODEL_PATH=/app/models/xgboost/claim_probability.json
XGBOOST_SEVERITY_MODEL_PATH=/app/models/xgboost/claim_severity.json
SPACY_MODEL_PATH=/app/models/spacy/insurance_ner

# Service URLs (used by the LLM service to call other services)
INGESTION_SERVICE_URL=http://ingestion:8000
PREDICTION_SERVICE_URL=http://prediction:8001
RAG_SERVICE_URL=http://rag:8002

# Application settings
LOG_LEVEL=INFO
RATE_LIMIT=10/minute

# Kaggle (for data download scripts only)
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key
